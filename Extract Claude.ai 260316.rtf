\
\pard\pardeftab720\partightenfactor0

\fs24 \cf4 \cb11 javascript\cb1 \
\pard\pardeftab720\partightenfactor0

\fs28 \cf15 \cb11 "5"\cf10  == \cf14 5\cf10     \cf12 // true  \'97 m\'eame valeur, types diff\'e9rents\cf10 \
\cf15 "5"\cf10  === \cf14 5\cf10    \cf12 // false \'97 types diff\'e9rents (texte vs nombre)\cf10 \cb1 \
\pard\pardeftab720\partightenfactor0

